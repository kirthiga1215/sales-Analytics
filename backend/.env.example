# Option A — Docker (docker compose up -d)
# DATABASE_URL="postgresql://sales:sales123@localhost:5432/sales_analytics?schema=public"

# Option B — Local PostgreSQL (Windows install, default superuser)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sales_analytics?schema=public"

PORT=4000
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,https://sales-analytics-7i3e.vercel.app,https://2dcdm61s-4000.inc1.devtunnels.ms
CORS_ORIGIN=http://localhost:3000,https://sales-analytics-7i3e.vercel.app,https://2dcdm61s-4000.inc1.devtunnels.ms
SEED_RECORD_COUNT=15000
